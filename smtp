#include <stdio.h>
#include <string.h>
#include <unistd.h>
#include <arpa/inet.h>

int main() {

    int server_fd, client_fd;
    char buffer[1024];
    struct sockaddr_in server_addr;

    // Create socket
    server_fd = socket(AF_INET, SOCK_STREAM, 0);

    // Server configuration
    server_addr.sin_family = AF_INET;
    server_addr.sin_port = htons(2525);
    server_addr.sin_addr.s_addr = INADDR_ANY;

    // Bind
    bind(server_fd, (struct sockaddr*)&server_addr, sizeof(server_addr));

    // Listen
    listen(server_fd, 1);

    printf("SMTP Server running on port 2525...\n");

    // Accept client
    client_fd = accept(server_fd, NULL, NULL);

    // Send greeting
    send(client_fd, "220 Simple SMTP Server Ready\r\n", 30, 0);

    while (1) {

        memset(buffer, 0, sizeof(buffer));

        int bytes = recv(client_fd, buffer, sizeof(buffer)-1, 0);

        if (bytes <= 0)
            break;

        printf("Client: %s", buffer);

        if (strncmp(buffer, "HELO", 4) == 0) {
            send(client_fd, "250 Hello\r\n", 11, 0);
        }

        else if (strncmp(buffer, "MAIL FROM", 9) == 0) {
            send(client_fd, "250 Sender OK\r\n", 15, 0);
        }

        else if (strncmp(buffer, "RCPT TO", 7) == 0) {
            send(client_fd, "250 Recipient OK\r\n", 18, 0);
        }

        else if (strncmp(buffer, "DATA", 4) == 0) {
            send(client_fd, "354 End data with <CRLF>.<CRLF>\r\n", 33, 0);
        }

        else if (strstr(buffer, "\r\n.\r\n") != NULL) {
            printf("Mail received:\n%s\n", buffer);
            send(client_fd, "250 Message accepted\r\n", 22, 0);
        }

        else if (strncmp(buffer, "QUIT", 4) == 0) {
            send(client_fd, "221 Bye\r\n", 9, 0);
            break;
        }

        else {
            send(client_fd, "250 OK\r\n", 8, 0);
        }
    }

    close(client_fd);
    close(server_fd);

    return 0;
}



#include <stdio.h>
#include <string.h>
#include <unistd.h>
#include <arpa/inet.h>

int main() {

    int sock;
    char buffer[1024];
    struct sockaddr_in server_addr;

    // Create socket
    sock = socket(AF_INET, SOCK_STREAM, 0);

    // Server configuration
    server_addr.sin_family = AF_INET;
    server_addr.sin_port = htons(2525);
    server_addr.sin_addr.s_addr = inet_addr("127.0.0.1");

    // Connect to server
    connect(sock, (struct sockaddr*)&server_addr, sizeof(server_addr));

    // Receive greeting
    recv(sock, buffer, sizeof(buffer), 0);
    printf("Server: %s", buffer);

    // HELO
    send(sock, "HELO localhost\r\n", 16, 0);
    recv(sock, buffer, sizeof(buffer), 0);
    printf("Server: %s", buffer);

    // MAIL FROM
    send(sock, "MAIL FROM:<a@test.com>\r\n", 24, 0);
    recv(sock, buffer, sizeof(buffer), 0);
    printf("Server: %s", buffer);

    // RCPT TO
    send(sock, "RCPT TO:<b@test.com>\r\n", 22, 0);
    recv(sock, buffer, sizeof(buffer), 0);
    printf("Server: %s", buffer);

    // DATA
    send(sock, "DATA\r\n", 6, 0);
    recv(sock, buffer, sizeof(buffer), 0);
    printf("Server: %s", buffer);

    // Message body
    send(sock, "Hello SMTP World!\r\n.\r\n", 21, 0);
    recv(sock, buffer, sizeof(buffer), 0);
    printf("Server: %s", buffer);

    // QUIT
    send(sock, "QUIT\r\n", 6, 0);
    recv(sock, buffer, sizeof(buffer), 0);
    printf("Server: %s", buffer);

    close(sock);

    return 0;
}




